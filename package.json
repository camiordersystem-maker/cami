{
  "name": "cami-order-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:member": "next dev -p 3000",
    "dev:admin": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx src/lib/db/migrate.ts",
    "db:migrate:pg": "npx tsx src/lib/db/migrate.pg.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "npx tsx src/lib/db/seed.ts",
    "seed:pg": "npx tsx src/lib/db/seed.pg.ts",
    "vercel-build": "npx tsx src/lib/db/migrate.pg.ts && npx tsx src/lib/db/seed.pg.ts && next build"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "next": "14.2.18",
    "next-auth": "^5.0.0-beta.31",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "resend": "^6.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
